# これをコピーして .env.local を作り、自分の Supabase の値を入れる。
# anon キーは Supabase ダッシュボード → Project Settings → API → Project API keys の anon public。
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# 一歩さん AI は Supabase Edge Function 側で GEMINI_API_KEY を読む。
# フロントの .env.local には Gemini キーを置かない。
# 設定例:
# supabase secrets set GEMINI_API_KEY=...
# supabase secrets set GEMINI_MODEL=gemini-3.1-flash-lite

# AIプロバイダ切り替え。既定は gemini。
# OpenAI Realtime 音声会話を使う場合は Vercel 側にも設定する。
# VITE_IPPO_AI_PROVIDER=gemini
# VITE_IPPO_AI_PROVIDER=openai-realtime

# OpenAI Realtime は Supabase Edge Function 側で OPENAI_API_KEY を読む。
# フロントの .env.local には OpenAI キーを置かない。
# 先に supabase/migrate_ai_realtime_sessions.sql を Supabase SQL Editor で実行する。
# 設定例:
# supabase secrets set OPENAI_API_KEY=...
# supabase secrets set SUPABASE_SERVICE_ROLE_KEY=...
# supabase secrets set OPENAI_REALTIME_MODEL=gpt-realtime-2.1-mini
# supabase secrets set OPENAI_REALTIME_VOICE=marin
# supabase secrets set OPENAI_REALTIME_MAX_SECONDS=180
# supabase secrets set OPENAI_REALTIME_DAILY_SESSION_LIMIT=20
# supabase secrets set OPENAI_REALTIME_MONTHLY_SESSION_LIMIT=300
# supabase secrets set OPENAI_REALTIME_MONTHLY_BUDGET_USD=5
# supabase secrets set OPENAI_REALTIME_ESTIMATED_COST_USD=0.0166
# supabase secrets set OPENAI_REALTIME_LIMIT_TZ_OFFSET_MINUTES=540
